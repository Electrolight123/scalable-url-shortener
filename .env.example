# PostgreSQL
POSTGRES_DB=urlshortener
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Spring Boot datasource
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/urlshortener
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Redis connection from backend container
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# JPA
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_OPEN_IN_VIEW=false

# Backend app config
APP_BASE_URL=http://localhost:8080
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
APP_JWT_SECRET=replace-this-with-a-secure-64-character-secret-key
APP_JWT_EXPIRATION_MS=86400000

# Rate limits
APP_RATE_LIMIT_URL_CREATION_PER_HOUR=20
APP_RATE_LIMIT_REDIRECTS_PER_MINUTE=100

# Frontend
VITE_API_BASE_URL=http://localhost:8080

# Exposed ports
BACKEND_PORT=8080
FRONTEND_PORT=5173

# Timezone
TZ=Asia/Kolkata